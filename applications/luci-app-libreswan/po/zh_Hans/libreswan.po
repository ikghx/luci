msgid "Libreswan is a free software implementation of the most widely supported and standardized VPN protocol using 'IPsec' and the Internet Key Exchange ('IKE')."
msgstr "Libreswan是使用“IPsec”和Internet密钥交换（“IKE”）的最广泛支持的标准化VPN协议的免费软件实现。"

msgid "IPsec Configuration"
msgstr "IPsec配置"

msgid "Libreswan - IPsec Configuration"
msgstr "Libreswan - IPsec配置"

msgid "configuration file: /etc/ipsec.conf, adjust the configuration file parameters as needed."
msgstr "配置文件：/etc/ipsec.conf，根据需要调整配置文件参数。"

msgid "Password Settings"
msgstr "密码设置"

msgid "Libreswan - Password Settings"
msgstr "Libreswan - 密码设置"

msgid "configuration file: /etc/ipsec.secrets, adjust the configuration file parameters as needed."
msgstr "配置文件：/etc/ipsec.secrets，根据需要调整配置文件参数。"
